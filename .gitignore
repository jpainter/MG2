.Rproj.user
.Rhistory
.RData
.Ruserdata
.DS_Store

# Session-cache .rds files written by the Shiny app during a live session.
# These are regenerated at runtime and should not be tracked.
inst/shiny/*.rds
/doc/
/Meta/

# Internal analysis scripts — not part of the package, may contain
# sensitive data paths and intermediate cached files.
/analysis/

# Sensitive/private content (Nigeria indicator analysis, security review response) —
# moved out of reports/ and given its own local-only git repo. Never track in MG2.
/private/

# Working docs — video files and scripts are large/internal, not for the repo.
docs/video/
docs/video_script.md

# Cloned external reference apps (e.g. Python tools being ported to R) — not part of MG2.
/dev/reference/
